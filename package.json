{
  "name": "kuvasta-mitat",
  "version": "1.0.0",
  "description": "Browser-based image measurement tool — draw lines, set a reference, get real-world dimensions in mm.",
  "type": "module",
  "scripts": {
    "dev":     "npx serve . --port 5173",
    "test":    "vitest run --coverage",
