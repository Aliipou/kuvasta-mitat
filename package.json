    "test:e2e":"playwright test",
    "lint":    "eslint src tests"
  },
  "devDependencies": {
    "@vitest/coverage-v8":   "^1.6.0",
    "vitest":                "^1.6.0",
    "jsdom":                 "^24.1.0",
    "@vitest/ui":            "^1.6.0",
    "@playwright/test":      "^1.44.0",
    "serve":                 "^14.2.3"
  }
}
